# Environment variables for NVIDIA-SmartRoute-CLI
HOST=0.0.0.0
PORT=9000
DEBUG=False
LOG_LEVEL=info

# NVIDIA NIM Configuration (use a dummy key for testing)
NVIDIA_API_KEY=dummy-key-for-testing-purposes-only

# Security Settings
ALLOWED_ORIGINS=*

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Application Settings
MODEL_CACHE_TTL=300
MAX_CONCURRENT_AGENTS=10
AGENT_TIMEOUT=300
TUI_REFRESH_RATE=1.0