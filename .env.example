# Environment variables for NVIDIA-SmartRoute-CLI
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=9000
DEBUG=False

# NVIDIA NIM Configuration
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Optional: pool of keys (comma-separated) to rotate past the ~40 req/min cap
# NVIDIA_API_KEYS=nvapi-key1,nvapi-key2,nvapi-key3
DEFAULT_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# Security Settings
ALLOWED_ORIGINS=*
# Inbound client auth on /v1/* (off by default). When enabled, callers must
# send a key via the X-API-Key header or an Authorization: Bearer token.
REQUIRE_API_KEY=False
# GATEWAY_API_KEYS=client-key-1,client-key-2
API_KEY_HEADER=X-API-Key

# Rate Limiting (inbound per-client on /v1/*, and per-key outbound budget)
ENABLE_RATE_LIMIT=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_PER_KEY=40

# Logging
LOG_LEVEL=INFO
LOG_JSON=False

# Response cache (identical non-streaming requests skip the upstream call)
ENABLE_CACHE=True
MODEL_CACHE_TTL=300
CACHE_MAX_ENTRIES=1000

# Reliability: on upstream model failure, retry the next-best model for the task
ENABLE_MODEL_FALLBACK=True
MAX_MODEL_FALLBACKS=2
# Circuit breaker: take a repeatedly-failing model out of rotation, then probe
CIRCUIT_BREAKER_ENABLED=True
CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_RESET_SECONDS=30

# Concurrency / backpressure (smooths bursts against upstream rate limits)
ENABLE_CONCURRENCY_LIMIT=True
MAX_INFLIGHT_REQUESTS=32
MAX_QUEUED_REQUESTS=64
QUEUE_TIMEOUT=30

# Metrics persistence (survive restarts)
PERSIST_METRICS=False
METRICS_FILE=.nvidia-smartroute-metrics.json
METRICS_SAVE_INTERVAL=60

# Application Settings
MAX_CONCURRENT_AGENTS=10
AGENT_TIMEOUT=300
AUTOSCALE_SEQUENTIAL=True
TUI_REFRESH_RATE=1.0
PID_FILE=.nvidia-smartroute.pid